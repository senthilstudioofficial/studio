import { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Quote, Star, ChevronLeft, ChevronRight } from 'lucide-react';

const testimonials = [
  {
    id: 1,
    name: 'Anjali & Karthik',
    role: 'Wedding Clients',
    content: "Senthil Studio didn't just take pictures; they captured the emotions of our wedding so perfectly. Every time we look at our album, we relive the magic. Their professionalism and cinematic eye are unmatched.",
    rating: 5,
    avatar: 'https://images.unsplash.com/photo-1583939003579-730e3918a45a?auto=format&fit=crop&q=80&w=200',
  },
  {
    id: 2,
    name: 'Mrs. Deepa R.',
    role: 'Newborn Shoot',
    content: 'The patience the team showed during our baby photoshoot was incredible. They knew exactly how to handle a newborn to get the best frames. Highly recommended for family events!',
    rating: 5,
    avatar: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&q=80&w=200',
  },
  {
    id: 3,
    name: 'Vikram Sethi',
    role: 'Fashion Model',
    content: 'Working with Senthil Studio for my portfolio was a game changer. Their lighting techniques and direction helped me land my first major modeling contract. Simply the best in Chennai.',
    rating: 5,
    avatar: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=200',
  },
];

export default function Testimonials() {
  const [currentIndex, setCurrentIndex] = useState(0);

  const next = () => setCurrentIndex((prev) => (prev + 1) % testimonials.length);
  const prev = () => setCurrentIndex((prev) => (prev - 1 + testimonials.length) % testimonials.length);

  return (
    <div className="pt-32 pb-24 bg-brand-black min-h-screen">
      <div className="max-w-7xl mx-auto px-6">
        <div className="text-center space-y-4 mb-20">
          <motion.h1
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            className="font-serif text-5xl md:text-7xl font-bold"
          >
            Client <span className="text-brand-gold">Stories</span>
          </motion.h1>
          <motion.p
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: 0.2 }}
            className="text-gray-500 uppercase tracking-widest text-sm font-bold"
          >
            What our clients say about their experience
          </motion.p>
        </div>

        <div className="relative max-w-5xl mx-auto">
          {/* Main Slider */}
          <div className="glass p-12 md:p-20 relative overflow-hidden">
            <Quote className="absolute top-10 left-10 text-brand-gold/10 w-32 h-32 -z-0" />
            
            <AnimatePresence mode="wait">
              <motion.div
                key={currentIndex}
                initial={{ opacity: 0, x: 50 }}
                animate={{ opacity: 1, x: 0 }}
                exit={{ opacity: 0, x: -50 }}
                className="relative z-10 space-y-12 text-center"
              >
                <div className="flex justify-center gap-1">
                  {[...Array(testimonials[currentIndex].rating)].map((_, i) => (
                    <Star key={i} size={20} className="text-brand-gold fill-brand-gold" />
                  ))}
                </div>
                
                <p className="text-xl md:text-3xl font-serif italic leading-relaxed text-gray-200">
                  "{testimonials[currentIndex].content}"
                </p>

                <div className="space-y-4">
                  <img
                    src={testimonials[currentIndex].avatar}
                    alt={testimonials[currentIndex].name}
                    className="w-20 h-20 rounded-full mx-auto border-2 border-brand-gold p-1 object-cover"
                    referrerPolicy="no-referrer"
                  />
                  <div>
                    <h4 className="font-bold text-xl">{testimonials[currentIndex].name}</h4>
                    <p className="text-brand-gold text-xs uppercase tracking-widest font-bold">{testimonials[currentIndex].role}</p>
                  </div>
                </div>
              </motion.div>
            </AnimatePresence>
          </div>

          {/* Navigation */}
          <div className="flex justify-center gap-6 mt-12">
            <button
              onClick={prev}
              className="p-4 glass rounded-full hover:bg-brand-gold hover:text-brand-black transition-all group"
            >
              <ChevronLeft size={24} className="group-hover:scale-125 transition-transform" />
            </button>
            <button
              onClick={next}
              className="p-4 glass rounded-full hover:bg-brand-gold hover:text-brand-black transition-all group"
            >
              <ChevronRight size={24} className="group-hover:scale-125 transition-transform" />
            </button>
          </div>
        </div>

        {/* Brand Logos/Section */}
        <div className="mt-32 pt-20 border-t border-white/5 text-center space-y-12">
            <p className="text-xs uppercase tracking-[0.4em] text-gray-600 font-bold">Trusted by Local Communities & Brands</p>
            <div className="flex flex-wrap justify-center gap-12 md:gap-24 opacity-30 grayscale hover:grayscale-0 transition-all duration-700">
                <span className="font-serif text-2xl font-bold">CHENNAI WEDDINGS</span>
                <span className="font-serif text-2xl font-bold">KIDS FASHION</span>
                <span className="font-serif text-2xl font-bold">EVENT PROS</span>
                <span className="font-serif text-2xl font-bold">PHOTO EXPO</span>
            </div>
        </div>
      </div>
    </div>
  );
}
